						</FontString>
						<FontString parentKey="OriginalPrice" hidden="true" inherits="GameFontNormalMed3" mixin="AutoScalingFontStringMixin" wordwrap="true" justifyH="CENTER">
							<Color color="GRAY_FONT_COLOR"/>
