	<!-- Default Product Card Template -->
	<Button name="DefaultCatalogShopCardTemplate" clipChildren="true" mixin="CatalogShopDefaultProductCardMixin" motionScriptsWhileDisabled="true" virtual="true">
		<KeyValues>
		<!--
		nonInteractive: for cases outside the catalog shop where behavior is overridden.
		useWideCardSettings: set for wide cards for determining the appropriate model scenes.
			<KeyValue key="nonInteractive" value="false" type="boolean"/>
			<KeyValue key="useWideCardSettings" value="false" type="boolean"/>
		-->
		<!-- hoverVisualEnabled: Controls the hover effect for the shop card. Some cards (like ones with Buy buttons) don't want to show hover state -->
			<KeyValue key="hoverVisualEnabled" value="true" type="boolean"/>
		</KeyValues>
		<Frames>
			<Frame parentKey="InvisibleMouseOverFrame" mixin="InvisibleMouseOverFrameMixin" enableMouse="true" hidden="true">
				<Scripts>
					<OnEnter method="OnEnter"/>
					<OnLeave method="OnLeave"/>
				</Scripts>
			</Frame>

			<Frame parentKey="BackgroundContainer" frameLevel="100" setAllPoints="true" >
				<Layers>
					<Layer level="BACKGROUND">
						<Texture parentKey="Background" setAllPoints="true" />
						<MaskTexture parentKey="BackgroundMask" setAllPoints="true" atlas="shop-card-wide-mask" hWrapMode="CLAMPTOBLACKADDITIVE" vWrapMode="CLAMPTOBLACKADDITIVE">
							<Size x="530" y="299"/>
							<Anchors>
								<Anchor point="CENTER" x="0" y="0"/>
							</Anchors>
							<MaskedTextures>
								<MaskedTexture childKey="Background"/>
							</MaskedTextures>
						</MaskTexture>
					</Layer>
				</Layers>
			</Frame>

			<ModelScene parentKey="ModelScene" frameLevel="200" hidden="true" inherits="NoCameraControlModelSceneMixinTemplate">
				<KeyValues>
					<KeyValue key="allowOverlappedModels" value="true" type="boolean"/>
				</KeyValues>
			</ModelScene>

			<Frame parentKey="SelectedContainer" frameLevel="300" setAllPoints="true" >
				<Layers>
					<Layer level="BORDER">
						<Texture parentKey="FrameBackground" setAllPoints="true" />
					</Layer>
				</Layers>
			</Frame>

			<Frame parentKey="ForegroundContainer" frameLevel="1000" setAllPoints="true" >
				<Layers>
					<Layer level="OVERLAY">
						<Texture parentKey="SquareIconBorder" atlas="shop-gold-rim" hidden="true" >
							<Size x="105" y="99"/>
							<Anchors>
								<Anchor point="TOP" x="0" y="-44" />
							</Anchors>
						</Texture>
						<Texture parentKey="CircleIconBorder" atlas="tokens-frame-large" hidden="true" >
							<Size x="109" y="109"/>
							<Anchors>
								<Anchor point="TOP" x="0" y="-40" />
							</Anchors>
						</Texture>
					</Layer>
					<Layer level="OVERLAY" textureSubLevel="1">
						<Texture parentKey="ProductCounter" atlas="tokens-counterbg-large" hidden="true" >
							<Size x="38" y="38" />
							<Anchors>
								<Anchor point="BOTTOMRIGHT" relativeKey="$parent.CircleIconBorder" x="0" y="0"/>
							</Anchors>
						</Texture>
						<FontString parentKey="ProductCounterText" inherits="Game22Font" justifyV="TOP" justifyH="CENTER" hidden="true" >
							<Anchors>
								<Anchor point="CENTER" relativeKey="$parent.ProductCounter" relativePoint="CENTER" x="0" y="0"/>
							</Anchors>
							<Color color="WHITE_FONT_COLOR"/>
						</FontString>
					</Layer>
					<Layer level="ARTWORK">
						<Texture parentKey="DividerTop" atlas="shop-card-label-bg" hidden="true" useAtlasSize="true" />
						<FontString parentKey="Price" inherits="GameFontNormalLarge" wordwrap="true" justifyH="RIGHT">
