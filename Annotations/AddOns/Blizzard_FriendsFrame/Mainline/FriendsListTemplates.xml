<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\Blizzard_SharedXML\UI.xsd">
	<Frame name="FriendsListSocialViewTemplate" inherits="SocialUIContactsFrameTemplate" mixin="FriendsListSocialViewMixin" virtual="true">
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnShow method="OnShow"/>
			<OnHide method="OnHide"/>
			<OnEvent method="OnEvent"/>
		</Scripts>
	</Frame>

	<Frame name="FriendsListSocialCardFavoriteDisplayTemplate" mixin="FriendsListSocialCardFavoriteDisplayMixin" inherits="UserScaledFrameTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="baseWidth" value="19" type="number"/>
			<KeyValue key="baseHeight" value="18" type="number"/>
			<KeyValue key="useScaleWeight" value="true" type="boolean"/>
			<KeyValue key="useScaleWeightForHeight" value="true" type="boolean"/>
			<KeyValue key="scaleWeight" value="0.5" type="number"/>
		</KeyValues>
		<Layers>
			<Layer level="ARTWORK">
				<Texture parentKey="Icon" atlas="friends-icon-favorites" setAllPoints="true"/>
			</Layer>
		</Layers>
		<Scripts>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
		</Scripts>
	</Frame>

	<Frame name="FriendsListSocialCardStateDisplayTemplate" mixin="FriendsListSocialCardStateDisplayMixin" inherits="UserScaledFrameTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="baseWidth" value="19" type="number"/>
			<KeyValue key="baseHeight" value="18" type="number"/>
			<KeyValue key="useScaleWeight" value="true" type="boolean"/>
			<KeyValue key="useScaleWeightForHeight" value="true" type="boolean"/>
			<KeyValue key="scaleWeight" value="0.5" type="number"/>
		</KeyValues>
		<Frames>
			<Frame parentKey="FavoriteDisplay" inherits="FriendsListSocialCardFavoriteDisplayTemplate" hidden="true">
				<Anchors>
					<Anchor point="CENTER"/>
				</Anchors>
			</Frame>
		</Frames>
	</Frame>

	<Frame name="FriendsListSocialCardGameIconHolderTemplate" virtual="true">
		<Size x="20" y="20"/>
		<Layers>
			<Layer level="ARTWORK">
				<Texture parentKey="Icon" setAllPoints="true"/>
			</Layer>
		</Layers>
	</Frame>

	<Button name="FriendsListSocialCardPartyButtonTemplate" inherits="SocialCardActionButtonTemplate" motionScriptsWhileDisabled="true" virtual="true" mixin="FriendsListSocialCardPartyButtonMixin">
		<Scripts>
			<OnClick method="OnClick"/>
		</Scripts>
	</Button>

	<Button name="FriendsListSocialCardRAFSummonButtonTemplate" inherits="SocialCardActionButtonTemplate" mixin="FriendsListSocialCardRAFSummonButtonMixin" motionScriptsWhileDisabled="true" virtual="true">
		<Layers>
			<Layer level="OVERLAY">
				<Texture parentKey="ActionIcon" atlas="RaidFrame-Icon-SummonPending" useAtlasSize="false">
					<Size x="24" y="24"/>
					<Anchors>
						<Anchor point="CENTER" y="1"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<Cooldown parentKey="Cooldown" inherits="CooldownFrameTemplate" drawBling="false" drawEdge="false" hideCountdownNumbers="true">
				<Anchors>
					<Anchor point="TOPLEFT" x="4" y="-3"/>
					<Anchor point="BOTTOMRIGHT" x="-4" y="5"/>
				</Anchors>
				<SwipeTexture file="Interface\HUD\UI-HUD-CoolDownManager-Icon-Swipe">
					<Color color="BLACK_FONT_COLOR" a="0.6"/>
				</SwipeTexture>
			</Cooldown>
		</Frames>
		<Scripts>
			<OnShow method="OnShow"/>
			<OnHide method="OnHide"/>
			<OnEvent method="OnEvent"/>
			<OnClick method="OnClick"/>
		</Scripts>
	</Button>

	<Button name="FriendsListSocialCardTemplate" registerForClicks="LeftButtonUp, RightButtonUp" mixin="FriendsListSocialCardMixin" virtual="true">
		<KeyValues>
			<KeyValue key="baseHeight" value="70" type="number"/>
			<KeyValue key="useScaleWeightForHeight" value="true" type="boolean"/>
			<KeyValue key="scaleWeight" value="0.6" type="number"/>

			<KeyValue key="presenceHolderXOffset" value="3" type="number"/>
			<KeyValue key="presenceHolderYOffset" value="-4" type="number"/>

			<KeyValue key="textHolderTopLeftXOffset" value="-4" type="number"/>
			<KeyValue key="textHolderTopLeftYOffset" value="3" type="number"/>
			<KeyValue key="textHolderRightXOffset" value="-6" type="number"/>
			<KeyValue key="textHolderBottomYOffset" value="5" type="number"/>

			<!-- For the Name/Level/Class row, which is 3 separate strings on the same line -->
			<KeyValue key="interStringTextSpacing" value="6" type="number"/>

			<!-- For the secondary text lines which live under the Name/Level/Class row -->
			<KeyValue key="lineSpacing" value="4" type="number"/>
			<KeyValue key="secondaryTextIndent" value="1" type="number"/>

			<KeyValue key="stateDisplayXOffset" value="2" type="number"/>
		</KeyValues>
		<Frames>
			<Frame parentKey="PresenceHolder" inherits="SocialCardPresenceHolderTemplate">
				<!-- Anchored dynamically in LayoutScaledContent -->
			</Frame>

			<Button parentKey="PartyButton" inherits="FriendsListSocialCardPartyButtonTemplate">
				<Anchors>
					<Anchor point="RIGHT" x="-4"/>
				</Anchors>
			</Button>

			<!-- Dynamically created based on the game state
			<Button parentKey="RAFSummonButton" inherits="FriendsListSocialCardRAFSummonButtonTemplate"/>
			-->

			<Frame parentKey="GameIconHolder" inherits="FriendsListSocialCardGameIconHolderTemplate" hidden="true">
				<Anchors>
					<Anchor point="RIGHT" relativeKey="$parent.PartyButton" relativePoint="LEFT" x="-6" y="1"/>
				</Anchors>
			</Frame>

			<Frame parentKey="TextHolder">
				<!-- Anchored dynamically in LayoutScaledContent -->
			</Frame>

			<Frame parentKey="StateDisplay" inherits="FriendsListSocialCardStateDisplayTemplate" hidden="true">
				<!-- Anchored dynamically in LayoutCompact/LayoutExpanded -->
			</Frame>
		</Frames>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture parentKey="Background" atlas="friends-card-default" setAllPoints="true"/>
			</Layer>
			<Layer level="ARTWORK">
				<FontString parentKey="FriendName" inherits="UserScaledFontHeader" justifyH="LEFT" justifyV="MIDDLE" text="" maxLines="1" wordwrap="false">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextHolder"/>
					</Anchors>
				</FontString>
				<FontString parentKey="Name" inherits="UserScaledFontBody" justifyH="LEFT" justifyV="MIDDLE" text="" maxLines="1" wordwrap="false">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.FriendName" relativePoint="BOTTOMLEFT" x="1" y="-4"/>
					</Anchors>
				</FontString>
				<FontString parentKey="Level" inherits="UserScaledFontBody" justifyH="LEFT" justifyV="MIDDLE" text="" maxLines="1" wordwrap="false">
					<Anchors>
						<Anchor point="LEFT" relativeKey="$parent.Name" relativePoint="RIGHT" x="6"/>
						<Anchor point="TOP" relativeKey="$parent.Name"/>
					</Anchors>
				</FontString>
				<FontString parentKey="Class" inherits="UserScaledFontBody" justifyH="LEFT" justifyV="MIDDLE" text="" maxLines="1" wordwrap="false">
					<Anchors>
						<Anchor point="LEFT" relativeKey="$parent.Level" relativePoint="RIGHT" x="6"/>
						<Anchor point="TOP" relativeKey="$parent.Level"/>
						<Anchor point="RIGHT" relativeKey="$parent.TextHolder"/>
					</Anchors>
				</FontString>
				<FontString parentKey="Location" inherits="UserScaledFontBody" justifyH="LEFT" justifyV="MIDDLE" text="" maxLines="1" wordwrap="false">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.Level" relativePoint="BOTTOMLEFT" y="-4"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<HighlightTexture atlas="friends-card-selected" alphaMode="ADD"/>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
		</Scripts>
	</Button>
</Ui>
