<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\Blizzard_SharedXML\UI.xsd">
	<Frame name="HousingBlueprintBudgetTemplate" mixin="HousingBlueprintBudgetMixin" inherits="VerticalLayoutFrame" parentArray="BudgetEntries" enableMouseMotion="true" hidden="true" virtual="true">
		<KeyValues>
		</KeyValues>
		<Layers>
			<Layer level="ARTWORK">
				<Texture parentKey="Icon" atlas="house-decor-budget-icon" texelSnappingBias="0.0" snapToPixelGrid="false">
					<Size x="32" y="32"/>
					<KeyValues>
						<KeyValue key="layoutIndex" value="1" type="number" />
						<KeyValue key="align" value="center" type="string"/>
					</KeyValues>
				</Texture>
				<FontString parentKey="Text" inherits="GameFontHighlightMedium" justifyV="MIDDLE" justifyH="CENTER">
					<Size x="0" y="20"/>
					<KeyValues>
						<KeyValue key="layoutIndex" value="2" type="number" />
						<KeyValue key="align" value="center" type="string"/>
					</KeyValues>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
		</Scripts>
	</Frame>

	<Frame name="HousingBlueprintBudgetsSectionTemplate" inherits="HorizontalLayoutFrame" virtual="true">
		<KeyValues>
			<KeyValue key="topPadding" value="30" type="number"/>
			<KeyValue key="spacing" value="16" type="number"/>
		</KeyValues>
		<Layers>
			<Layer level="ARTWORK">
				<FontString parentKey="Label" inherits="GameFontHighlightMedium" justifyV="MIDDLE" justifyH="LEFT">
					<Size y="20"/>
					<Anchors>
						<Anchor point="TOP"/>
						<Anchor point="LEFT" relativeKey="$parent.$parent" x="8"/>
						<Anchor point="RIGHT" relativeKey="$parent.$parent" x="-8"/>
					</Anchors>
					<KeyValues>
						<KeyValue key="ignoreInLayout" value="true" type="boolean"/>
					</KeyValues>
				</FontString>
				<Texture parentKey="Divider" atlas="housing-dashboard-divider-horz-tile" texelSnappingBias="0.0" snapToPixelGrid="false">
					<Size y="1"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.Label" relativePoint="BOTTOMLEFT" y="-2"/>
						<Anchor point="TOPRIGHT" relativeKey="$parent.Label" relativePoint="BOTTOMRIGHT" y="-2"/>
					</Anchors>
					<KeyValues>
						<KeyValue key="ignoreInLayout" value="true" type="boolean"/>
					</KeyValues>
				</Texture>
			</Layer>
		</Layers>
	</Frame>

	<Frame name="HousingBlueprintBudgetsContainerTemplate" mixin="HousingBlueprintBudgetsContainerMixin" inherits="VerticalLayoutFrame" virtual="true">
		<KeyValues>
			<KeyValue key="spacing" value="16" type="number"/>
			<KeyValue key="expand" value="true" type="boolean" />
			<KeyValue key="topPadding" value="5" type="number"/>
			<KeyValue key="leftPadding" value="10" type="number"/>
			<KeyValue key="rightPadding" value="10" type="number"/>
			<KeyValue key="bottomPadding" value="5" type="number"/>
		</KeyValues>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture parentKey="Background" atlas="housing-basic-panel-innerblackbox">
					<KeyValues>
						<KeyValue key="ignoreInLayout" value="true" type="boolean"/>
					</KeyValues>
					<Anchors>
						<Anchor point="TOPLEFT" x="-10" y="10"/>
						<Anchor point="BOTTOMRIGHT" x="10" y="-10"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<Frame parentKey="InteriorBudgets" inherits="HousingBlueprintBudgetsSectionTemplate">
				<KeyValues>
					<KeyValue key="layoutIndex" value="1" type="number" />
					<KeyValue key="expand" value="true" type="boolean" />
				</KeyValues>
			</Frame>
			<Frame parentKey="ExteriorBudgets" inherits="HousingBlueprintBudgetsSectionTemplate">
				<KeyValues>
					<KeyValue key="layoutIndex" value="2" type="number" />
					<KeyValue key="expand" value="true" type="boolean" />
				</KeyValues>
			</Frame>
		</Frames>
		<Scripts>
			<OnLoad method="OnLoad"/>
		</Scripts>
	</Frame>
</Ui>
