<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\Blizzard_SharedXML\UI.xsd">
	<EventFrame name="HousingBlueprintContentGroupTemplate" mixin="HousingBlueprintContentGroupMixin" virtual="true">
		<Size y="26"/>
		<KeyValues>
			<KeyValue key="expand" value="true" type="boolean"/>
		</KeyValues>
		<Frames>
			<Button parentKey="Header" inherits="ListHeaderThreeSliceTemplate" setAllPoints="true" registerForClicks="LeftButtonUp">
			</Button>
		</Frames>
		<Scripts>
			<OnLoad method="OnLoad"/>
		</Scripts>
	</EventFrame>

	<Frame name="HousingBlueprintContentListFrame" mixin="HousingBlueprintContentListFrameMixin" inherits="HousingBlueprintBaseFrameTemplate" enableMouse="true" parent="UIParent" hidden="true">
		<KeyValues>
			<KeyValue key="headerText" value="HOUSING_BLUEPRINT_CONTENT_LIST_HEADER" type="global"/>
		</KeyValues>
		<Size x="384" y="500"/>
		<Anchors>
			<Anchor point="TOP"/>
		</Anchors>
		<Layers>
			<Layer level="ARTWORK">
				<FontString parentKey="CountText" inherits="GameFontHighlight" justifyV="MIDDLE" justifyH="LEFT">
					<Size y="12"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.Header" relativePoint="BOTTOMLEFT" x="16" y="-10"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Frame parentKey="MissingOnlyCheckbox" inherits="ResizeLayoutFrame" enableMouse="true" propagateMouseInput="Both">
				<Size y="29"/>
				<Anchors>
					<Anchor point="TOPRIGHT" relativeKey="$parent.Header" relativePoint="BOTTOMRIGHT" x="-16" y="-4"/>
				</Anchors>
				<Layers>
					<Layer level="ARTWORK">
						<FontString parentKey="Text" text="HOUSING_BLUEPRINT_CONTENT_MISSING_ONLY" inherits="GameFontHighlight" justifyV="MIDDLE" justifyH="RIGHT">
							<Size y="12"/>
							<Anchors>
								<Anchor point="RIGHT" x="0" y="0"/>
							</Anchors>
						</FontString>
					</Layer>
				</Layers>
				<Frames>
					<CheckButton parentKey="Checkbox" inherits="MinimalCheckboxArtTemplate">
						<Size x="24" y="24"/>
						<Anchors>
							<Anchor point="RIGHT" relativeKey="$parent.Text" relativePoint="LEFT" x="-5" y="0"/>
						</Anchors>
					</CheckButton>
				</Frames>
			</Frame>
			<Frame parentKey="ScrollBox" inherits="WowScrollBoxList">
				<KeyValues>
					<!-- How many rows are scrolled past at once via scroll wheel -->
					<KeyValue key="wheelPanScalar" value="1" type="number"/>
				</KeyValues>
				<Anchors>
					<Anchor point="TOPLEFT" relativeKey="$parent.CountText" relativePoint="BOTTOMLEFT" x="5" y="-15"/>
					<Anchor point="BOTTOMRIGHT" x="-30" y="50"/>
				</Anchors>
			</Frame>
			<EventFrame parentKey="ScrollBar" inherits="MinimalScrollBar">
				<KeyValues>
					<KeyValue key="hideIfUnscrollable" value="false" type="boolean"/>
				</KeyValues>
				<Anchors>
					<Anchor point="TOPLEFT" relativeKey="$parent.ScrollBox" relativePoint="TOPRIGHT" x="5" y="0"/>
					<Anchor point="BOTTOMLEFT" relativeKey="$parent.ScrollBox" relativePoint="BOTTOMRIGHT" x="5" y="0"/>
				</Anchors>
			</EventFrame>
			<Button parentKey="BottomCloseButton" inherits="UIPanelDynamicResizeButtonTemplate" text="HOUSING_BLUEPRINT_CONTENT_LIST_CLOSE_BUTTON">
				<Size x ="152" y="28"/>
				<Anchors>
					<Anchor point="BOTTOM" x="0" y="10"/>
				</Anchors>
			</Button>
		</Frames>
		<Layers>
			<Layer level="BACKGROUND" textureSubLevel="1">
				<Texture parentKey="ScrollBackground">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.ScrollBox"  x="-5" y="5"/>
						<Anchor point="BOTTOMRIGHT" relativeKey="$parent.ScrollBar" x="5" y="0"/>
					</Anchors>
					<Color r="0" g="0" b="0" a="0.6"/>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad inherit="prepend" method="OnLoad"/>
			<OnShow inherit="prepend" method="OnShow"/>
			<OnHide inherit="prepend" method="OnHide"/>
			<OnEvent method="OnEvent"/>
		</Scripts>
	</Frame>
</Ui>
