<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\Blizzard_SharedXML\UI.xsd">
	<Frame name="HousingBlueprintBudgetTemplate" mixin="HousingBlueprintBudgetMixin" inherits="ResizeLayoutFrame" parentArray="BudgetEntries" enableMouseMotion="true" hidden="true" virtual="true">
		<KeyValues>
			<!-- <KeyValue key="icon" value="house-decor-budget-icon" type="string"/> -->
			<!-- <KeyValue key="tooltipText" value="" type="global" /> -->
			<KeyValue key="fixedHeight" value="42" type="number"/>
		</KeyValues>
		<Layers>
			<Layer level="ARTWORK">
				<Texture parentKey="Icon" atlas="house-decor-budget-icon" texelSnappingBias="0.0" snapToPixelGrid="false">
					<Size x="32" y="32"/>
					<Anchors>
						<Anchor point="LEFT"/>
					</Anchors>
				</Texture>
				<FontString parentKey="Text" inherits="GameFontHighlightLarge" justifyV="MIDDLE" justifyH="LEFT">
					<Size x="0" y="20"/>
					<Anchors>
						<Anchor point="LEFT" relativeKey="$parent.Icon" relativePoint="RIGHT" x="5"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
		</Scripts>
	</Frame>

	<Frame name="HousingBlueprintContentSummaryScriptsTemplate" mixin="HousingBlueprintContentSummaryMixin" virtual="true">
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnShow method="OnShow"/>
			<OnHide method="OnHide"/>
			<OnEvent method="OnEvent"/>
		</Scripts>
	</Frame>

	<Frame name="HousingBlueprintContentSummaryTemplate" inherits="VerticalLayoutFrame, HousingBlueprintContentSummaryScriptsTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="minimumWidth" value="300" type="number"/>
			<KeyValue key="minimumHeight" value="100" type="number"/>
			<KeyValue key="align" value="center" type="string"/>
			<KeyValue key="spacing" value="10" type="number"/>
			<KeyValue key="topPadding" value="12" type="number"/>
			<KeyValue key="leftPadding" value="20" type="number"/>
			<KeyValue key="rightPadding" value="20" type="number"/>
		</KeyValues>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture parentKey="Background" atlas="housing-basic-panel-innerblackbox" alpha="0.6">
					<KeyValues>
						<KeyValue key="ignoreInLayout" value="true" type="boolean"/>
					</KeyValues>
					<Anchors>
						<Anchor point="TOPLEFT"/>
						<Anchor point="BOTTOMRIGHT"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<Frame parentKey="BudgetsContainer" inherits="GridLayoutFrame" hidden="true">
				<KeyValues>
					<KeyValue key="layoutIndex" value="1" type="number" />
					<KeyValue key="align" value="center" type="string"/>
					<KeyValue key="stride" value="2" type="number"/>
					<KeyValue key="isHorizontal" value="true" type="boolean"/>
					<KeyValue key="layoutFramesGoingRight" value="true" type="boolean"/>
					<KeyValue key="layoutFramesGoingUp" value="false" type="boolean"/>
					<KeyValue key="paddingToLast" value="true" type="boolean"/>
					<KeyValue key="childXPadding" value="18" type="number"/>
					<KeyValue key="childYPadding" value="5" type="number"/>
				</KeyValues>
				<Frames>
					<Frame parentKey="RoomBudget" inherits="HousingBlueprintBudgetTemplate">
						<KeyValues>
							<KeyValue key="layoutIndex" value="1" type="number" />
							<KeyValue key="icon" value="house-room-limit-icon" type="string"/>
							<KeyValue key="tooltipText" value="HOUSING_BLUEPRINT_ROOM_BUDGET_TOOLTIP" type="global" />
						</KeyValues>
					</Frame>
					<Frame parentKey="IndoorDecorBudget" inherits="HousingBlueprintBudgetTemplate">
						<KeyValues>
							<KeyValue key="layoutIndex" value="2" type="number" />
							<KeyValue key="icon" value="house-decor-budget-icon" type="string"/>
							<KeyValue key="tooltipText" value="HOUSING_BLUEPRINT_DECOR_INTERIOR_BUDGET_TOOLTIP" type="global" />
						</KeyValues>
					</Frame>
					<Frame parentKey="OutdoorDecorBudget" inherits="HousingBlueprintBudgetTemplate">
						<KeyValues>
							<KeyValue key="layoutIndex" value="3" type="number" />
							<KeyValue key="icon" value="house-decor-exteriorbudget-icon" type="string"/>
							<KeyValue key="tooltipText" value="HOUSING_BLUEPRINT_DECOR_EXTERIOR_BUDGET_TOOLTIP" type="global" />
						</KeyValues>
					</Frame>
				</Frames>
			</Frame>
			<Frame parentKey="CountListContainer" inherits="HorizontalLayoutFrame" hidden="true">
				<KeyValues>
					<KeyValue key="layoutIndex" value="2" type="number"/>
					<KeyValue key="spacing" value="20" type="number"/>
					<KeyValue key="bottomPadding" value="12" type="number"/>
					<KeyValue key="align" value="center" type="string"/>
				</KeyValues>
				<Layers>
					<Layer level="ARTWORK">
						<FontString parentKey="ContentsCountText" inherits="GameFontHighlightMedium">
							<Size y="20"/>
							<KeyValues>
								<KeyValue key="layoutIndex" value="1" type="number"/>
								<KeyValue key="expand" value="true" type="boolean"/>
							</KeyValues>
						</FontString>
					</Layer>
				</Layers>
				<Frames>
					<Button parentKey="ContentsListButton" inherits="UIPanelDynamicResizeButtonTemplate" text="HOUSING_BLUEPRINT_IMPORT_VALIDATION_LIST_BUTTON" motionScriptsWhileDisabled="true">
						<Size x ="60" y="28"/>
						<KeyValues>
							<KeyValue key="layoutIndex" value="2" type="number"/>
						</KeyValues>
					</Button>
				</Frames>
			</Frame>
			<Frame parentKey="LoadingSpinner" inherits="SpinnerTemplate" hidden="true">
				<KeyValues>
					<KeyValue key="ignoreInLayout" value="true" type="boolean"/>
				</KeyValues>
				<Size x="100" y="100"/>
				<Anchors>
					<Anchor point="CENTER" x="0" y="0"/>
				</Anchors>
			</Frame>
		</Frames>
	</Frame>

	<Frame name="HousingBlueprintContentSummaryVerticalTemplate" inherits="VerticalLayoutFrame, HousingBlueprintContentSummaryScriptsTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="minimumWidth" value="300" type="number"/>
			<KeyValue key="minimumHeight" value="100" type="number"/>
			<KeyValue key="align" value="center" type="string"/>
			<KeyValue key="spacing" value="10" type="number"/>
			<KeyValue key="topPadding" value="12" type="number"/>
			<KeyValue key="leftPadding" value="20" type="number"/>
			<KeyValue key="rightPadding" value="20" type="number"/>
		</KeyValues>
		<Frames>
			<Frame parentKey="BudgetsContainer" inherits="VerticalLayoutFrame" hidden="true">
				<KeyValues>
					<KeyValue key="layoutIndex" value="1" type="number" />
					<KeyValue key="align" value="left" type="string"/>
					<KeyValue key="bottomPadding" value="20" type="number"/>
					<KeyValue key="spacing" value="0" type="number"/>
				</KeyValues>
				<Frames>
					<Frame parentKey="RoomBudget" inherits="HousingBlueprintBudgetTemplate">
						<KeyValues>
							<KeyValue key="layoutIndex" value="1" type="number" />
							<KeyValue key="icon" value="house-room-limit-icon" type="string"/>
							<KeyValue key="tooltipText" value="HOUSING_BLUEPRINT_ROOM_BUDGET_TOOLTIP" type="global" />
						</KeyValues>
					</Frame>
					<Frame parentKey="IndoorDecorBudget" inherits="HousingBlueprintBudgetTemplate">
						<KeyValues>
							<KeyValue key="layoutIndex" value="2" type="number" />
							<KeyValue key="icon" value="house-decor-budget-icon" type="string"/>
							<KeyValue key="tooltipText" value="HOUSING_BLUEPRINT_DECOR_INTERIOR_BUDGET_TOOLTIP" type="global" />
						</KeyValues>
					</Frame>
					<Frame parentKey="OutdoorDecorBudget" inherits="HousingBlueprintBudgetTemplate">
						<KeyValues>
							<KeyValue key="layoutIndex" value="3" type="number" />
							<KeyValue key="icon" value="house-decor-exteriorbudget-icon" type="string"/>
							<KeyValue key="tooltipText" value="HOUSING_BLUEPRINT_DECOR_EXTERIOR_BUDGET_TOOLTIP" type="global" />
						</KeyValues>
					</Frame>
				</Frames>
			</Frame>
			<Frame parentKey="CountListContainer" hidden="true">
				<Size y="70"/>
				<KeyValues>
					<KeyValue key="layoutIndex" value="2" type="number"/>
					<KeyValue key="expand" value="true" type="boolean"/>
				</KeyValues>
				<Layers>
					<Layer level="ARTWORK">
						<FontString parentKey="ContentsCountText" inherits="GameFontHighlightMedium" justifyH="LEFT">
							<Size y="20"/>
							 <Anchors>
								<Anchor point="TOPLEFT"/>
								<Anchor point="TOPRIGHT"/>
							 </Anchors>
						</FontString>
					</Layer>
				</Layers>
				<Frames>
					<Button parentKey="ContentsListButton" inherits="UIPanelDynamicResizeButtonTemplate" text="HOUSING_BLUEPRINT_IMPORT_VALIDATION_LIST_BUTTON" motionScriptsWhileDisabled="true">
						<Size x ="60" y="28"/>
						<Anchors>
							<Anchor point="TOPLEFT" relativeKey="$parent.ContentsCountText" relativePoint="BOTTOMLEFT" x="0" y="-20"/>
						</Anchors>
					</Button>
				</Frames>
			</Frame>
			<Frame parentKey="LoadingSpinner" inherits="SpinnerTemplate" hidden="true">
				<KeyValues>
					<KeyValue key="ignoreInLayout" value="true" type="boolean"/>
				</KeyValues>
				<Size x="100" y="100"/>
				<Anchors>
					<Anchor point="CENTER" x="0" y="0"/>
				</Anchors>
			</Frame>
		</Frames>
	</Frame>
</Ui>
