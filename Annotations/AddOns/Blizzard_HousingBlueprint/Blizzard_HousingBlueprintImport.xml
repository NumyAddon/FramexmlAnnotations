<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\Blizzard_SharedXML\UI.xsd">
	<Frame name="HousingBlueprintImportContentTemplate" virtual="true">
		<Anchors>
			<Anchor point="TOP" relativeKey="$parent.Header" relativePoint="BOTTOM" y="-20"/>
			<Anchor point="LEFT" x="15"/>
		</Anchors>
		<KeyValues>
			<KeyValue key="minimumWidth" value="320" type="number" />
		</KeyValues>
	</Frame>

	<Frame name="HousingBlueprintImportLoadingFrame" mixin="HousingBlueprintImportLoadingFrameMixin" frameStrata="HIGH" frameLevel="4000" parent="UIParent" hidden="true" setAllPoints="true">
		<Frames>
			<!-- Prevents interacting with anything behind this dialog while open -->
			<Button parentKey="InputBlocker" frameLevel="1" setAllPoints="true">
				<Layers>
					<Layer level="BACKGROUND" textureSubLevel="-1">
						<Texture setAllPoints="true">
							<Color r="0" g="0" b="0" a="0.5"/>
						</Texture>
					</Layer>
				</Layers>
			</Button>
			<Frame parentKey="Spinner" inherits="SpinnerTemplate">
				<Size x="142" y="142"/>
				<Anchors>
					<Anchor point="CENTER" x="0" y="0"/>
				</Anchors>
			</Frame>
		</Frames>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnShow method="OnShow"/>
			<OnHide method="OnHide"/>
			<OnEvent method="OnEvent"/>
		</Scripts>
	</Frame>

	<Frame name="HousingBlueprintImportFrame" mixin="HousingBlueprintImportFrameMixin" inherits="ResizeLayoutFrame, HousingBlueprintBaseFrameTemplate" parent="UIParent" hidden="true">
		<KeyValues>
			<KeyValue key="minimumHeight" value="100" type="number"/>
			<KeyValue key="widthPadding" value="15" type="number"/>
			<KeyValue key="heightPadding" value="20" type="number"/>
			<KeyValue key="headerText" value="HOUSING_BLUEPRINT_IMPORT_HEADER" type="global"/>
			<KeyValue key="isExclusive" value="true" type="boolean"/>
			<KeyValue key="openSoundKit" value="SOUNDKIT.HOUSING_BLUEPRINTS_IMPORT_OPEN" type="global"/>
			<KeyValue key="closeSoundKit" value="SOUNDKIT.HOUSING_BLUEPRINTS_IMPORT_CLOSE" type="global"/>
		</KeyValues>
		<Anchors>
			<Anchor point="TOP"/>
		</Anchors>
		<Frames>
			<Frame parentKey="InputContent" mixin="HousingBlueprintImportInputContentMixin" inherits="HousingBlueprintImportContentTemplate, VerticalLayoutFrame">
				<Size y="200"/>
				<Layers>
					<Layer level="ARTWORK">
						<FontString parentKey="ShareCodeLabel" inherits="GameFontHighlightSmall" text="HOUSING_BLUEPRINT_IMPORT_SHARECODE_LABEL" justifyH="LEFT">
							<Size y="12"/>
							<KeyValues>
								<KeyValue key="layoutIndex" value="1" type="number"/>
								<KeyValue key="expand" value="true" type="boolean"/>
							</KeyValues>
						</FontString>
						<FontString parentKey="NoticeText" inherits="GameFontHighlight">
							<Size y="72"/>
							<KeyValues>
								<KeyValue key="layoutIndex" value="3" type="number"/>
								<KeyValue key="expand" value="true" type="boolean"/>
							</KeyValues>
						</FontString>
					</Layer>
				</Layers>
				<Frames>
					<ScrollFrame parentKey="ShareCodeBox" inherits="InputScrollFrameTemplate">
						<Size y="26" x="310"/>
						<KeyValues>
							<KeyValue key="hideCharCount" value="true" type="boolean"/>
							<KeyValue key="layoutIndex" value="2" type="number"/>
							<KeyValue key="expand" value="true" type="boolean"/>
							<KeyValue key="topPadding" value="5" type="number"/>
							<KeyValue key="bottomPadding" value="5" type="number"/>
							<KeyValue key="leftPadding" value="5" type="number"/>
							<KeyValue key="rightPadding" value="5" type="number"/>
						</KeyValues>
					</ScrollFrame>
					<Button parentKey="NextButton" inherits="UIPanelDynamicResizeButtonTemplate" text="HOUSING_BLUEPRINT_IMPORT_INPUT_NEXT_BUTTON" motionScriptsWhileDisabled="true">
						<Size x ="152" y="28"/>
						<KeyValues>
							<KeyValue key="layoutIndex" value="4" type="number"/>
							<KeyValue key="align" value="center" type="string"/>
						</KeyValues>
					</Button>
					<DropdownButton parentKey="GearDropdown" inherits="UIPanelIconDropdownButtonTemplate">
						<Anchors>
							<Anchor point="RIGHT" relativeKey="$parent.ShareCodeLabel" x="10" y="10"/>
						</Anchors>
						<KeyValues>
							<KeyValue key="ignoreInLayout" value="true" type="boolean"/>
						</KeyValues>
					</DropdownButton>
				</Frames>
				<Scripts>
					<OnLoad method="OnLoad"/>
				</Scripts>
			</Frame>

			<Frame parentKey="ValidationContent" mixin="HousingBlueprintImportValidationContentMixin" inherits="HousingBlueprintImportContentTemplate, VerticalLayoutFrame">
				<KeyValues>
					<KeyValue key="minimumWidth" value="100" type="number" />
					<KeyValue key="spacing" value="10" type="number"/>
					<KeyValue key="bottomPadding" value="0" type="number"/>
				</KeyValues>
				<Frames>
					<Frame parentKey="ContentSummary" inherits="HousingBlueprintContentSummaryTemplate">
						<KeyValues>
							<KeyValue key="layoutIndex" value="1" type="number"/>
						</KeyValues>
					</Frame>
					<DropdownButton parentKey="GearDropdown" inherits="UIPanelIconDropdownButtonTemplate">
						<Anchors>
							<Anchor point="TOPRIGHT" x="10" y="10"/>
						</Anchors>
						<KeyValues>
							<KeyValue key="ignoreInLayout" value="true" type="boolean"/>
						</KeyValues>
					</DropdownButton>
					<Button parentKey="ImportButton" inherits="UIPanelDynamicResizeButtonTemplate" text="HOUSING_BLUEPRINT_IMPORT_VALIDATION_IMPORT_BUTTON" motionScriptsWhileDisabled="true">
						<Size x ="152" y="28"/>
						<KeyValues>
							<KeyValue key="layoutIndex" value="3" type="number"/>
							<KeyValue key="align" value="center" type="string"/>
							<KeyValue key="topPadding" value="10" type="number"/>
						</KeyValues>
					</Button>
				</Frames>
				<Layers>
					<Layer level="ARTWORK">
						<FontString parentKey="NoticeText" inherits="GameFontHighlight" wordwrap="true" hidden="true">
							<KeyValues>
								<KeyValue key="layoutIndex" value="2" type="number"/>
								<KeyValue key="expand" value="true" type="boolean"/>
								<KeyValue key="topPadding" value="10" type="number"/>
							</KeyValues>
						</FontString>
					</Layer>
				</Layers>
				<Scripts>
					<OnLoad method="OnLoad"/>
				</Scripts>
			</Frame>
		</Frames>
		<Scripts>
			<OnHide inherit="prepend" method="OnHide"/>
		</Scripts>
	</Frame>
</Ui>
