<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\Blizzard_SharedXML\UI.xsd">
	<Frame name="ManagedFrameTemplate" mixin="ManagedFrameMixin" virtual="true">
		<KeyValues>
			<KeyValue key="isManagedFrame" value="true" type="boolean"/>
		</KeyValues>
		<Scripts>
			<OnShow method="OnShow"/>
			<OnHide method="OnHide"/>
		</Scripts>
	</Frame>

	<Frame name="BottomManagedFrameTemplate" inherits="ManagedFrameTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="layoutParent" value="BottomManagedFrameContainer" type="global"/>
			<KeyValue key="align" value="center" type="string"/>
			<KeyValue key="hideWhenActionBarIsOverriden" value="true" type="boolean"/>
			<KeyValue key="ignoreInLayoutWhenActionBarIsOverriden" value="false" type="boolean"/>
			<KeyValue key="isBottomManagedFrame" value="true" type="boolean"/>
		</KeyValues>
	</Frame>

	<Frame name="RightManagedFrameTemplate" inherits="ManagedFrameTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="layoutParent" value="RightManagedFrameContainer" type="global"/>
			<KeyValue key="align" value="right" type="string"/>
			<KeyValue key="hideWhenActionBarIsOverriden" value="false" type="boolean"/>
			<KeyValue key="isRightManagedFrame" value="true" type="boolean"/>
		</KeyValues>
	</Frame>

	<Frame name="ManagedFrameContainerBaseTemplate" parent="UIParent" inherits="VerticalLayoutFrame" mixin="ManagedFrameContainerMixin" virtual="true">
		<KeyValues>
			<KeyValue key="respectChildScale" value="true" type="boolean"/>
		</KeyValues>
		<Frames>
			<Frame parentKey="BottomManagedLayoutContainer" inherits="HorizontalLayoutFrame" hidden="true">
				<KeyValues>
					<KeyValue key="layoutIndex" value="500" type="number"/>
					<KeyValue key="spacing" value="12" type="number"/>
				</KeyValues>
			</Frame>
		</Frames>
		<Scripts>
			<OnLoad method="OnLoad"/>
		</Scripts>
	</Frame>
</Ui>
