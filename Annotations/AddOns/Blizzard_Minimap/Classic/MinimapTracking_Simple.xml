<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\Blizzard_SharedXML\UI.xsd">
	<Frame name="MiniMapTracking" mixin="MinimapTrackingSimpleMixin" enableMouse="true" hidden="true">
		<Size x="33" y="33"/>
		<Anchors>
			<Anchor point="TOPLEFT" x="11" y="-26"/>
		</Anchors>
		<Layers>
			<Layer level="BORDER">
				<Texture name="$parentIcon">
					<Size x="24" y="24"/>
					<Anchors>
						<Anchor point="CENTER" x="2" y="-2"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="ARTWORK">
				<Texture name="$parentBorder" file="Interface\Minimap\MiniMap-TrackingBorder">
					<Size x="64" y="64"/>
					<Anchors>
						<Anchor point="TOPLEFT"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnEvent method="OnEvent"/>
			<OnEnter method="OnMouseUp"/>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
		</Scripts>
	</Frame>
</Ui>
