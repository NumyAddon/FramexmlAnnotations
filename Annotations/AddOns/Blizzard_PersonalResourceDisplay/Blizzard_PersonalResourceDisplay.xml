<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\Blizzard_SharedXML\UI.xsd">
	<StatusBar name="PersonalResourceStatusBar" inherits="TextStatusBar" virtual="true">
		<KeyValues>
			<KeyValue key="showPercentage" value="true" type="boolean"/>
			<KeyValue key="showNumeric" value="true" type="boolean"/>
			<KeyValue key="capNumericDisplay" value="true" type="boolean"/>
			<KeyValue key="controlsShownState" value="false" type="boolean"/>
		</KeyValues>
		<BarTexture atlas="UI-HUD-CoolDownManager-Bar" texelSnappingBias="0" snapToPixelGrid="false"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture atlas="UI-HUD-CoolDownManager-Bar-BG" texelSnappingBias="0" snapToPixelGrid="false">
					<Anchors>
						<Anchor point="TOPLEFT" x="-2" y="3"/>
						<Anchor point="BOTTOMRIGHT" x="6" y="-7"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="OVERLAY">
				<FontString parentKey="TextString" inherits="TextStatusBarText">
					<Anchors>
						<Anchor point="RIGHT" x="-5" y="0"/>
					</Anchors>
				</FontString>
				<FontString parentKey="RightText" inherits="TextStatusBarText">
					<Anchors>
						<Anchor point="RIGHT" x="-5" y="0"/>
					</Anchors>
				</FontString>
				<FontString parentKey="LeftText" inherits="TextStatusBarText">
					<Anchors>
						<Anchor point="LEFT" x="5" y="0"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</StatusBar>
	
	<Frame name="PersonalResourceDisplayFrame" inherits="EditModePersonalResourceDisplaySystemTemplate" parent="UIParent" mixin="PersonalResourceDisplayMixin" roleset="unitFrames">
		<Size x="200" y="75"/>
		<Frames>
			<!-- Health -->
			<Frame parentKey="HealthBarsContainer">
				<!-- Size dynamically managed in Lua. -->
				<Anchors>
					<Anchor point="TOP"/>
				</Anchors>
				<Frames>
					<StatusBar parentKey="TempMaxHealthLoss" hidden="true" drawLayer="BACKGROUND" mixin="TempMaxHealthLossMixin" frameLevel="100">
						<BarTexture parentKey="TempMaxHealthLossTexture" atlas="UI-HUD-UnitFrame-Target-PortraitOn-Bar-TempHPLoss"/>
						<Anchors>
							<Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
							<Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
						</Anchors>
					</StatusBar>
					<StatusBar parentKey="healthBar" inherits="PersonalResourceStatusBar">
						<Anchors>
							<Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
							<Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
						</Anchors>
						<Layers>
							<Layer level="BORDER" textureSubLevel="5">
								<Texture parentKey="myHealPrediction" file="Interface/TargetingFrame/UI-TargetingFrame-BarFill" hidden="true"/>
								<Texture parentKey="otherHealPrediction" file="Interface/TargetingFrame/UI-TargetingFrame-BarFill" hidden="true"/>
								<Texture parentKey="totalAbsorb"/>
							</Layer>
							<Layer level="BORDER" textureSubLevel="6">
								<Texture parentKey="totalAbsorbOverlay"/>
							</Layer>
							<Layer level="ARTWORK" textureSubLevel="1">
								<Texture parentKey="myHealAbsorb" hidden="true"/>
								<Texture parentKey="myHealAbsorbLeftShadow" file="Interface\RaidFrame\Absorb-Edge" hidden="true"/>
								<Texture parentKey="myHealAbsorbRightShadow" file="Interface\RaidFrame\Absorb-Edge" hidden="true">
									<TexCoords left="1" right="0" top="0" bottom="1"/>
								</Texture>
							</Layer>
							<Layer level="ARTWORK" textureSubLevel="2">
								<Texture parentKey="overAbsorbGlow" hidden="true"/>
								<Texture parentKey="overHealAbsorbGlow" hidden="true"/>
							</Layer>
						</Layers>
					</StatusBar>
				</Frames>
			</Frame>

			<!-- Power (Mana, Rage, etc.) -->
			<StatusBar parentKey="PowerBar" inherits="PersonalResourceStatusBar">
				<!-- Size dynamically managed in Lua. -->
				<Anchors>
					<Anchor point="TOP" relativeKey="$parent.HealthBarsContainer" relativePoint="BOTTOM"/>
				</Anchors>
				<Layers>
					<Layer level="ARTWORK">
						<Texture parentKey="ManaCostPredictionBar" file="Interface\TargetingFrame\UI-StatusBar">
							<Color r="0.0" g="0.447" b="1.0"/>
						</Texture>
					</Layer>
				</Layers>
				<Frames>
					<Frame parentKey="FeedbackFrame" setAllPoints="true" useParentLevel="true" inherits="BuilderSpenderFrame"/>
					<Frame parentKey="FullPowerFrame" inherits="FullResourcePulseFrame">
						<Size x="200" y="17"/>
						<Anchors>
							<Anchor point="RIGHT"/>
						</Anchors>
					</Frame>
				</Frames>
				<BarColor r="0" g="0" b="1"/>
			</StatusBar>

			<!-- Alternate Power -->
			<StatusBar parentKey="AlternatePowerBar" inherits="PersonalResourceStatusBar" hidden="true">
				<KeyValues>
					<KeyValue key="showPercentage" value="false" type="boolean"/>
					<KeyValue key="disableMaxValue" value="true" type="boolean"/>
				</KeyValues>
				<!-- Size dynamically managed in Lua. -->
				<BarColor r="0" g="0" b="1"/>
			</StatusBar>

			<!-- Class Frame -->
			<Frame parentKey="ClassFrameContainer" hidden="true">
				<Size x="200" y="15"/>
			</Frame>
		</Frames>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnShow method="OnShow"/>
			<OnHide method="OnHide"/>
			<OnEvent method="OnEvent"/>
			<OnUpdate method="OnUpdate"/>
		</Scripts>
	</Frame>
</Ui>
