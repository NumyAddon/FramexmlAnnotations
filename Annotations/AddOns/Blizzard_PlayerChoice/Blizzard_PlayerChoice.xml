<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\..\..\..\WoW\Data\Interface\AddOns\Blizzard_SharedXML\UI.xsd">
	
	<Frame name="PlayerChoiceFrame" frameStrata="HIGH" parent="UIParent" toplevel="true" inherits="HorizontalLayoutFrame" mixin="PlayerChoiceFrameMixin" hidden="true" >
		<Size x="600" y="544"/>
		<KeyValues>
			<KeyValue key="fixedWidth" value="100" type="number"/>
			<KeyValue key="expand" value="true" type="boolean"/>
			<KeyValue key="skipChildLayout" value="true" type="boolean"/>
			<KeyValue key="skipLayoutOnShow" value="true" type="boolean"/>
		</KeyValues>
		<Anchors>
			<Anchor point="CENTER"/>
		</Anchors>
		<Layers>
			<Layer level="OVERLAY">
				<Texture parentKey="BorderOverlay">
					<!-- Anchoring reset dynamically in PlayerChoiceFrameMixin:SetupFrame -->
					<Anchors>
						<Anchor point="TOPLEFT" x="-6" y="6"/>
						<Anchor point="BOTTOMRIGHT" x="6" y="-6"/>
					</Anchors>
				</Texture>
				<Texture parentKey="GridDivider" atlas="playerchoice-gold-divider" useAtlasSize="true" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" x="-334" y="-32"/>
					</Anchors>
				</Texture>
				<FontString parentKey="GridNoSelectionHeader" font="GameFontHighlightHuge2" justifyV="TOP" justifyH="CENTER" hidden="true">
					<Size x="288" y="0"/>
					<Anchors>
						<Anchor point="LEFT" relativeKey="$parent.GridDivider" relativePoint="RIGHT"/>
						<Anchor point="RIGHT" x="-40" y="0"/>
						<Anchor point="BOTTOM" relativeKey="$parent" relativePoint="CENTER"/>
					</Anchors>
				</FontString>
				<FontString parentKey="GridNoSelectionDescription" font="GameFontNormal" justifyV="TOP" justifyH="CENTER" hidden="true">
					<Size x="100" y="300"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.GridNoSelectionHeader" relativePoint="BOTTOMLEFT" x="30" y="-20"/>
						<Anchor point="TOPRIGHT" relativeKey="$parent.GridNoSelectionHeader" relativePoint="BOTTOMRIGHT" x="-30" y="-20"/>
					</Anchors>
				</FontString>
				<FontString parentKey="GridSelectionHeader" font="GameFontHighlightHuge2" justifyV="TOP" justifyH="CENTER" hidden="true">
					<Size x="288" y="0"/>
					<Anchors>
						<Anchor point="LEFT" relativeKey="$parent.GridDivider" relativePoint="RIGHT"/>
						<Anchor point="RIGHT" x="-40" y="0"/>
						<Anchor point="TOP" x="0" y="-160"/>
					</Anchors>
				</FontString>
				<FontString parentKey="GridSelectionDescription" font="GameFontNormal" justifyV="TOP" justifyH="CENTER" hidden="true">
					<Size x="100" y="300"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.GridSelectionHeader" relativePoint="BOTTOMLEFT" x="30" y="-20"/>
						<Anchor point="TOPRIGHT" relativeKey="$parent.GridNoSelectionHeader" relativePoint="BOTTOMRIGHT" x="-30" y="-20"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Frame parentKey="NineSlice" inherits="NineSlicePanelTemplate" setAllPoints="true">
				<!-- Anchoring reset dynamically in PlayerChoiceFrameMixin:SetupFrame  -->
				<Anchors>
					<Anchor point="TOPLEFT" x="-6" y="6"/>
					<Anchor point="BOTTOMRIGHT" x="6" y="-6"/>
				</Anchors>
			</Frame>
			<Frame parentKey="BlackBackground" frameLevel="450" enableMouse="true" setAllPoints="true" hidden="true">
				<Layers>
					<Layer level="ARTWORK">
						<Texture setAllPoints="true">
							<Color color="BLACK_FONT_COLOR" a="0.80"/>
						</Texture>
					</Layer>
				</Layers>
			</Frame>
			<Frame parentKey="Header" inherits="ResizeLayoutFrame" frameLevel="510">
				<Anchors>
					<Anchor point="BOTTOM" relativePoint="TOP" />
				</Anchors>
				<Layers>
					<Layer level="BORDER">
						<Texture parentKey="Texture">
							<Anchors>
								<Anchor point="TOP" />
							</Anchors>
						</Texture>
					</Layer>
				</Layers>
			</Frame>
			<Frame parentKey="Background" clipChildren="true" useParentLevel="true">
				<Anchors>
					<Anchor point="TOPLEFT"/>
					<Anchor point="BOTTOMRIGHT" x="-2"/>
				</Anchors>
				<Layers>
					<Layer level="BACKGROUND">
						<Texture parentKey="BackgroundTile" horizTile="true" vertTile="true" setAllPoints="true"/>
					</Layer>
				</Layers>
			</Frame>
			<Frame parentKey="Title">
				<Size x="500" y="85"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="50" y="-33"/>
					<Anchor point="TOPRIGHT" x="-50" y="-33"/>
				</Anchors>
				<Layers>
					<Layer level="BACKGROUND">
						<Texture parentKey="Left">
							<Anchors>
								<Anchor point="LEFT"/>
							</Anchors>
						</Texture>
						<Texture parentKey="Right">
							<Anchors>
								<Anchor point="RIGHT"/>
							</Anchors>
						</Texture>
					</Layer>
					<Layer level="BACKGROUND" textureSubLevel="-1">
						<Texture parentKey="Middle" horizTile="true">
							<Anchors>
								<Anchor point="TOPLEFT" relativeKey="$parent.Left" relativePoint="TOPRIGHT" x="-60"/>
								<Anchor point="BOTTOMRIGHT" relativeKey="$parent.Right" relativePoint="BOTTOMLEFT" x="60"/>
							</Anchors>
						</Texture>
					</Layer>
					<Layer level="ARTWORK">
						<FontString parentKey="Text" inherits="SystemFont_Shadow_Large" justifyH="CENTER">
							<Anchors>
								<Anchor point="CENTER" relativeKey="$parent.Middle"/>
							</Anchors>
						</FontString>
					</Layer>
				</Layers>
			</Frame>
			<Button parentKey="CloseButton" inherits="UIPanelCloseButton" frameLevel="510">
				<Anchors>
					<Anchor point="TOPRIGHT" />
				</Anchors>
			</Button>
			<ModelScene parentKey="BorderLayerModelScene" drawLayer="BORDER"  inherits="ScriptAnimatedModelSceneTemplate" alpha="0.5" setAllPoints="true"/>

			<!--Frames below this point are used for the Grid layout.-->
			<Frame parentKey="PagingControls" inherits="PagingControlsHorizontalTemplate">
				<Anchors>
					<Anchor point="BOTTOM" x="-150" y="63"/>
				</Anchors>
			</Frame>
			<Frame parentKey="WidgetContainer" inherits="UIWidgetContainerTemplate" mixin="PlayerChoiceWidgetContainerMixin" hidden="true">
				<KeyValues>
					<KeyValue key="showAndHideOnWidgetSetRegistration" value="false" type="boolean"/>
				</KeyValues>
				<Anchors>
					<Anchor point="BOTTOM" relativeKey="$parent" relativePoint="BOTTOMRIGHT" x="-178" y="110"/>
				</Anchors>
			</Frame>
			<Frame parentKey="OptionButtonsContainer" inherits="PlayerChoiceBaseOptionButtonsContainer">
				<Anchors>
					<Anchor point="TOP" relativeKey="$parent.WidgetContainer" relativePoint="BOTTOM" x="0" y="-5"/>
				</Anchors>
			</Frame>
		</Frames>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnEvent method="OnEvent"/>
			<OnShow method="OnShow"/>
			<OnHide method="OnHide"/>
		</Scripts>
	</Frame>
</Ui>
