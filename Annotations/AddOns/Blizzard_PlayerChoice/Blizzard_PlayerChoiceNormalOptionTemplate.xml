<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\..\..\..\WoW\Data\Interface\AddOns\Blizzard_SharedXML\UI.xsd">

	<Frame name="PlayerChoiceNormalOptionTemplate" inherits="PlayerChoiceBaseOptionTemplate, VerticalLayoutFrame" mixin="PlayerChoiceNormalOptionTemplateMixin" virtual="true">
		<KeyValues>
			<KeyValue key="fixedWidth" value="240" type="number"/>
		</KeyValues>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture parentKey="Background">
					<Anchors>
						<Anchor point="TOPLEFT" x="-8" y="-36"/>
						<Anchor point="BOTTOMRIGHT" x="8" y="-34"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="ARTWORK">
				<Texture parentKey="ArtworkBorder" inherits="PlayerChoiceBaseCenteredFrame">
					<KeyValues>
						<KeyValue key="layoutIndex" value="2" type="number"/>
						<KeyValue key="topPadding" value="-16" type="number"/>
					</KeyValues>
				</Texture>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="-1">
				<Texture parentKey="Artwork">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.ArtworkBorder" x="10" y="-9"/>
						<Anchor point="BOTTOMRIGHT" relativeKey="$parent.ArtworkBorder" x="-10" y="9"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<Frame parentKey="Header" inherits="PlayerChoiceBaseCenteredFrame, ResizeLayoutFrame">
				<KeyValues>
					<KeyValue key="layoutIndex" value="1" type="number"/>
				</KeyValues>
				<Layers>
					<Layer level="BORDER">
						<Texture parentKey="Ribbon" atlas="UI-Frame-Horde-Ribbon" useAtlasSize="true">
							<Anchors>
								<Anchor point="TOPLEFT" />
							</Anchors>
						</Texture>
					</Layer>
				</Layers>
				<Frames>
					<Frame parentKey="Contents" inherits="HorizontalLayoutFrame" useParentLevel="true">
						<KeyValues>
							<KeyValue key="fixedHeight" value="32" type="number"/>
							<KeyValue key="spacing" value="5" type="number"/>
							<KeyValue key="ignoreInLayout" value="true" type="boolean"/>
						</KeyValues>
						<Anchors>
							<Anchor point="CENTER" />
						</Anchors>
						<Layers>
							<Layer level="ARTWORK">
								<Texture parentKey="Icon" hidden="true">
									<Anchors>
										<Anchor point="TOPLEFT" />
									</Anchors>
									<KeyValues>
										<KeyValue key="layoutIndex" value="1" type="number"/>
									</KeyValues>
								</Texture>
								<FontString parentKey="Text" font="SystemFont_Med3" justifyV="MIDDLE" maxLines="2">
									<Size y="30"/>
									<KeyValues>
										<KeyValue key="layoutIndex" value="2" type="number"/>
									</KeyValues>
									<Color r="0" g="0" b="0"/>
								</FontString>
							</Layer>
						</Layers>
					</Frame>
				</Frames>
			</Frame>
			<Frame parentKey="SubHeader" inherits="PlayerChoiceBaseCenteredFrame" hidden="true">
				<Size x="207" y="30"/>
				<KeyValues>
					<KeyValue key="layoutIndex" value="3" type="number"/>
					<KeyValue key="topPadding" value="2" type="number"/>
					<KeyValue key="bottomPadding" value="-8" type="number"/>
				</KeyValues>
				<Layers>
					<Layer level="BACKGROUND">
						<Texture parentKey="BG">
							<Size x="207" y="30"/>
							<Anchors>
								<Anchor point="TOP"/>
							</Anchors>
						</Texture>
					</Layer>
					<Layer level="ARTWORK">
						<FontString parentKey="Text" font="Game16Font" justifyV="MIDDLE" maxLines="1">
							<Size x="180" y="20"/>
							<Anchors>
								<Anchor point="CENTER"/>
							</Anchors>
							<Color r="1" g="1" b="1"/>
						</FontString>
					</Layer>
				</Layers>
			</Frame>
			<Frame parentKey="Rewards" inherits="PlayerChoiceBaseOptionRewardsTemplate" hidden="true">
				<KeyValues>
					<KeyValue key="layoutIndex" value="15" type="number"/>
					<KeyValue key="topPadding" value="5" type="number"/>
				</KeyValues>
			</Frame>
		</Frames>
	</Frame>

	<Button name="PlayerChoiceNormalOptionGridTemplate" mixin="PlayerChoiceNormalOptionGridTemplateMixin" virtual="true">
		<Size x="232" y="123"/>
		<Layers>
			<Layer level="ARTWORK" textureSubLevel="1">
				<Texture parentKey="TextBackground" useAtlasSize="true">
					<Anchors>
						<Anchor point="BOTTOMLEFT" x="0" y="2"/>
					</Anchors>
				</Texture>
				<!--Unimplemented-->
				<Texture parentKey="Complete" atlas="playerchoice-checkmark-gradient" useAtlasSize="true" hidden="true">
					<Anchors>
						<Anchor point="BOTTOMRIGHT" x="-4" y="5"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="0">
				<Texture parentKey="Artwork">
					<Size x="214" y="107"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="10" y="-7"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="2">
				<Texture parentKey="ArtworkAdditive" alpha=".4" alphaMode="ADD" hidden="true">
					<Size x="214" y="107"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="10" y="-7"/>
					</Anchors>
				</Texture>
				<MaskTexture atlas="playerchoice-tile-mask" hWrapMode="CLAMPTOBLACKADDITIVE" vWrapMode="CLAMPTOBLACKADDITIVE">
					<Size x="214" y="107"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.Artwork" relativePoint="TOPLEFT"/>
					</Anchors>
					<MaskedTextures>
						<MaskedTexture childKey="Artwork"/>
						<MaskedTexture childKey="ArtworkAdditive"/>
					</MaskedTextures>
				</MaskTexture>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="3">
				<Texture parentKey="ArtworkBorder"/>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="4">
				<Texture parentKey="Selected" atlas="playerchoice-tile-selected" useAtlasSize="true" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.ArtworkBorder" x="-4" y="4"/>
						<Anchor point="BOTTOMRIGHT" relativeKey="$parent.ArtworkBorder" x="5" y="-5"/>
					</Anchors>
				</Texture>
				<FontString parentKey="Text" font="SystemFont_Med3" justifyV="TOP" justifyH="LEFT" maxLines="1">
					<Size y="20"/>
					<Anchors>
						<Anchor point="BOTTOMLEFT" x="22" y="12"/>
					</Anchors>
				</FontString>
				<FontString parentKey="SubHeaderText" font="GameFontNormalSmall2" justifyV="BOTTOM" justifyH="LEFT" maxLines="1" hidden="true">
					<Size y="20"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.Text" relativePoint="BOTTOMLEFT" x="0" y="10"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</Button>
</Ui>
