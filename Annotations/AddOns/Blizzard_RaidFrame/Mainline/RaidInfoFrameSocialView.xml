<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\Blizzard_SharedXML\UI.xsd">
	<Button name="SocialUIRaidInfoContentFrameTemplate" virtual="true" mixin="SocialUIRaidInfoContentFrameMixin">
		<Size x="300" y="40"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture atlas="friends-card-raidBG" setAllPoints="true"/>
			</Layer>
			<Layer level="ARTWORK">
				<FontString parentKey="name" inherits="GameFontNormal" justifyH="LEFT" maxLines="1">
					<Size x="150"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="5" y="-10"/>
					</Anchors>
				</FontString>
				<FontString parentKey="difficulty" inherits="GameFontHighlightSmall" justifyH="LEFT" maxLines="1">
					<Size x="150"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.name" relativePoint="BOTTOMLEFT"/>
						<Anchor point="TOPRIGHT" relativeKey="$parent.name" relativePoint="BOTTOMRIGHT"/>
					</Anchors>
				</FontString>
				<FontString parentKey="reset" inherits="GameFontHighlightSmall" justifyH="RIGHT" maxLines="1">
					<Anchors>
						<Anchor point="TOPRIGHT" x="-5" y="-10"/>
					</Anchors>
				</FontString>
				<FontString parentKey="extended" inherits="GameFontHighlightSmall" justifyH="RIGHT" text="EXTENDED"	maxLines="1">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.reset" relativePoint="BOTTOMLEFT"/>
						<Anchor point="TOPRIGHT" relativeKey="$parent.reset" relativePoint="BOTTOMRIGHT"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<HighlightTexture file="Interface\QuestFrame\UI-QuestTitleHighlight" alphaMode="ADD">
			<Anchors>
				<Anchor point="TOPLEFT" x="-10" y="-2"/>
				<Anchor point="BOTTOMRIGHT" x="10" y="-2"/>
			</Anchors>
		</HighlightTexture>
		<Scripts>
			<OnMouseDown method="OnMouseDown"/>
			<OnMouseUp method="OnMouseUp"/>
			<OnClick method="OnClick"/>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
		</Scripts>
	</Button>
	
	<Frame name="SocialUIRaidInfoFrameTemplate" virtual="true" mixin="SocialUIRaidInfoFrameMixin, SocialUISystemMixin">
		<Size x="345" y="250"/>
		<Layers>
			<Layer level="BACKGROUND" textureSubLevel="1">
				<Texture parentKey="TopInset" file="Interface\FrameGeneral\UI-Background-Rock" horizTile="true" vertTile="true">
					<Size y="36"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="6" y="-6"/>
						<Anchor point="TOPRIGHT" x="-6" y="6"/>
					</Anchors>
				</Texture>
				<Texture parentKey="BottomInset" file="Interface\FrameGeneral\UI-Background-Rock" horizTile="true" vertTile="true">
					<Size y="36"/>
					<Anchors>
						<Anchor point="BOTTOMLEFT" x="6" y="6"/>
						<Anchor point="BOTTOMRIGHT" x="-6" y="6"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="BACKGROUND">
				<Texture>
					<Anchors>
						<Anchor point="TOPLEFT" x="6" y="-6"/>
						<Anchor point="BOTTOMRIGHT" x="-6" y="6"/>
					</Anchors>
					<Color r="0" g="0" b="0" a="0.9"/>
				</Texture>
			</Layer>
			<Layer level="BACKGROUND" textureSubLevel="2">
				<Texture parentKey="TopInsetEdge" atlas="_UI-Frame-DiamondMetal-EdgeTop" useAtlasSize="true" horizTile="true">
					<Anchors>
						<Anchor point="BOTTOMLEFT" x="4" y="-21" relativeKey="$parent.TopInset"/>
						<Anchor point="BOTTOMRIGHT" x="-4" y="-21" relativeKey="$parent.TopInset"/>
					</Anchors>
				</Texture>
				<Texture parentKey="BottomInsetEdge" atlas="_UI-Frame-DiamondMetal-EdgeTop" useAtlasSize="true" horizTile="true">
					<Anchors>
						<Anchor point="TOPLEFT" x="4" y="7" relativeKey="$parent.BottomInset"/>
						<Anchor point="TOPRIGHT" x="-4" y="7" relativeKey="$parent.BottomInset"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="ARTWORK">
				<FontString inherits="GameFontHighlight" text="INSTANCE" >
					<Size y="24"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="18" y="-12"/>
					</Anchors>
				</FontString>
				<FontString inherits="GameFontHighlight" text="LOCK_EXPIRE" >
					<Size y="24"/>
					<Anchors>
						<Anchor point="TOPRIGHT" x="-40" y="-12"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Frame parentKey="Border" frameLevel="2" setAllPoints="true"/>
			<Button parentKey="CloseButton" inherits="UIPanelCloseButtonNoScripts">
				<Anchors>
					<Anchor point="TOPRIGHT" x="-12" y="-12"/>
				</Anchors>
			</Button>
			<Frame parentKey="ScrollBox" inherits="WowScrollBoxList">
				<Size x="292" y="157"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="16" y="-48"/>
				</Anchors>
			</Frame>
			<EventFrame parentKey="ScrollBar" inherits="MinimalScrollBar">
				<Anchors>
					<Anchor point="TOPLEFT" relativeKey="$parent.ScrollBox" relativePoint="TOPRIGHT" x="10" y="-2"/>
					<Anchor point="BOTTOMLEFT" relativeKey="$parent.ScrollBox" relativePoint="BOTTOMRIGHT" x="10" y="4"/>
				</Anchors>
			</EventFrame>
			<Button parentKey="ExtendButton" inherits="SharedButtonTemplate" mixin="SocialUIRaidInfoExtendMixin" text="EXTEND_RAID_LOCK">
				<KeyValues>
					<KeyValue key="fitTextCanWidthDecrease" value="false" type="boolean"/>
					<KeyValue key="fitTextWidthPadding" value="40" type="number"/>
				</KeyValues>
				<Size x="200" y="30"/>
				<Anchors>
					<Anchor point="BOTTOM" y="10"/>
				</Anchors>
				<Scripts>
					<OnShow method="OnShow"/>
					<OnClick method="OnClick"/>
				</Scripts>
			</Button>
		</Frames>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnShow method="OnShow"/>
			<OnHide method="OnHide"/>
			<OnEvent method="OnEvent"/>
		</Scripts>
	</Frame>
</Ui>
