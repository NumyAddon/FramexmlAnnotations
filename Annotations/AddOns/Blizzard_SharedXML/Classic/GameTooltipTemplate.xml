<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\UI.xsd">
	<GameTooltip name="GameTooltipCommonTemplate" frameStrata="TOOLTIP" hidden="true" virtual="true">
		<Layers>
			<Layer level="OVERLAY">
				<Texture parentKey="TopOverlay" hidden="true">
					<Anchors>
						<Anchor point="CENTER" relativePoint="TOP" x="0" y="1" />
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="OVERLAY">
				<Texture parentKey="BottomOverlay" hidden="true">
					<Anchors>
						<Anchor point="CENTER" relativePoint="BOTTOM" x="0" y="2" />
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
	</GameTooltip>

	<GameTooltip name="GameTooltipTemplate" clampedToScreen="true" inherits="GameTooltipCommonTemplate, TooltipBackdropTemplate" mixin="GameTooltipMixin" virtual="true">
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentTextLeft1" parentKey="TextLeft1" inherits="GameTooltipHeaderText" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" x="10" y="-10"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight1" parentKey="TextRight1" inherits="GameTooltipHeaderText" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft1" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft2" parentKey="TextLeft2" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft1" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight2" parentKey="TextRight2" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft2" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft3" parentKey="TextLeft3" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft2" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight3" parentKey="TextRight3" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft3" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft4" parentKey="TextLeft4" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft3" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight4" parentKey="TextRight4" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft4" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft5" parentKey="TextLeft5" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft4" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight5" parentKey="TextRight5" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft5" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft6" parentKey="TextLeft6" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft5" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight6" parentKey="TextRight6" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft6" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft7" parentKey="TextLeft7" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft6" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight7" parentKey="TextRight7" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft7" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft8" parentKey="TextLeft8" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft7" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight8" parentKey="TextRight8" inherits="GameTooltipText" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft8" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<Texture name="$parentTexture1" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture2" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture3" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture4" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture5" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture6" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture7" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture8" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture9" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture10" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<StatusBar name="$parentStatusBar" mixin="GameTooltipStatusBarMixin" hidden="true">
				<Size x="0" y="8"/>
				<Anchors>
					<Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" x="2" y="-1"/>
					<Anchor point="TOPRIGHT" relativePoint="BOTTOMRIGHT" x="-2" y="-1"/>
				</Anchors>
				<Scripts>
					<OnValueChanged method="OnValueChanged"/>
				</Scripts>
				<BarTexture name="$parentTexture" file="Interface\TargetingFrame\UI-TargetingFrame-BarFill"/>
			</StatusBar>
		</Frames>
		<Scripts>
			<OnLoad method="OnLoadGameTooltip" inherit="prepend"/>
			<OnHide method="OnHide"/>
			<OnTooltipSetDefaultAnchor method="OnTooltipSetDefaultAnchor"/>
			<OnTooltipAddMoney method="OnTooltipAddMoney"/>
			<OnTooltipCleared method="OnTooltipCleared"/>
		</Scripts>
	</GameTooltip>
	<GameTooltip name="ShoppingTooltipTemplate" inherits="GameTooltipCommonTemplate, TooltipBackdropTemplate" mixin="ShoppingTooltipMixin" virtual="true">
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentTextLeft1" parentKey="TextLeft1" inherits="GameFontNormalSmall" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" x="10" y="-10"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight1" parentKey="TextRight1" inherits="GameFontNormal" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft1" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft2" parentKey="TextLeft2" inherits="GameFontNormal" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft1" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight2" parentKey="TextRight2" inherits="GameFontHighlightSmall" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft2" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft3" parentKey="TextLeft3" inherits="GameFontHighlightSmall" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft2" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight3" parentKey="TextRight3" inherits="GameFontHighlightSmall" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft3" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextLeft4" parentKey="TextLeft4" inherits="GameTooltipTextSmall" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.TextLeft3" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
				<FontString name="$parentTextRight4" parentKey="TextRight4" inherits="GameFontHighlightSmall" hidden="true">
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TextLeft4" relativePoint="LEFT" x="40" y="0"/>
					</Anchors>
				</FontString>
				<Texture name="$parentTexture1" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture2" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
				<Texture name="$parentTexture3" hidden="true">
					<Size x="12" y="12"/>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad inherit="prepend" function="GameTooltip_OnLoad"/>
			<OnTooltipCleared method="OnTooltipCleared"/>
		</Scripts>
	</GameTooltip>
	<Frame name="TooltipMoneyFrameTemplate" inherits="SmallMoneyFrameTemplate" mixin="" virtual="true">
		<Size x="128" y="13"/>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentPrefixText" inherits="GameFontHighlight">
					<Anchors>
						<Anchor point="LEFT" x="-4" y="0"/>
					</Anchors>
				</FontString>
				<FontString name="$parentSuffixText" inherits="GameFontHighlight">
					<Anchors>
						<Anchor point="LEFT"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad function="SmallMoneyFrame_OnLoad"/>
		</Scripts>
	</Frame>
	<StatusBar name="TooltipStatusBarTemplate" mixin="TooltipStatusBarMixin" virtual="true">
		<Size x="0" y="12"/>
		<Layers>
			<Layer level="OVERLAY">
				<FontString parentKey="Text" inherits="GameFontHighlightSmall">
					<Anchors>
						<Anchor point="LEFT" x="5" y="0"/>
					</Anchors>
				</FontString>
				<Texture file="Interface\Tooltips\UI-StatusBar-Border">
					<Size x="128" y="16"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="-2" y="2"/>
						<Anchor point="TOPRIGHT" x="2" y="-2"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad method="OnLoad"/>
		</Scripts>
		<BarTexture name="$parentTexture" file="Interface\TargetingFrame\UI-TargetingFrame-BarFill"/>
	</StatusBar>

	<!-- Large status bar with 2 dividers -->
	<Frame name="TooltipProgressBarTemplate" virtual="true">
		<Size x="219" y="25"/>
		<Frames>
			<StatusBar parentKey="Bar" drawLayer="BACKGROUND" minValue="0" maxValue="100" defaultValue="0">
				<Size x="215" y="15"/>
				<Anchors>
					<Anchor point="CENTER" x="0" y="0"/>
				</Anchors>
				<Layers>
					<Layer level="BORDER">
						<Texture parentKey="BorderLeft" file="Interface\PaperDollInfoFrame\UI-Character-Skills-BarBorder">
							<Size x="9" y="22"/>
							<Anchors>
								<Anchor point="LEFT" x="-3" y="0"/>
							</Anchors>
							<TexCoords left="0.007843" right="0.043137" top="0.193548" bottom="0.774193"/>
						</Texture>
						<Texture parentKey="BorderRight" file="Interface\PaperDollInfoFrame\UI-Character-Skills-BarBorder">
							<Size x="9" y="22"/>
							<Anchors>
								<Anchor point="RIGHT" x="3" y="0"/>
							</Anchors>
							<TexCoords left="0.043137" right="0.007843" top="0.193548" bottom="0.774193"/>
						</Texture>
						<Texture parentKey="BorderMid" file="Interface\PaperDollInfoFrame\UI-Character-Skills-BarBorder">
							<Anchors>
								<Anchor point="TOPLEFT" relativeKey="$parent.BorderLeft" relativePoint="TOPRIGHT"/>
								<Anchor point="BOTTOMRIGHT" relativeKey="$parent.BorderRight" relativePoint="BOTTOMLEFT"/>
							</Anchors>
							<TexCoords left="0.113726" right="0.1490196" top="0.193548" bottom="0.774193"/>
						</Texture>
					</Layer>
					<Layer level="ARTWORK">
						<Texture parentKey="LeftDivider" file="Interface\GuildFrame\GuildFrame">
							<Size x="7" y="14"/>
							<Anchors>
								<Anchor point="LEFT" x="66" y="0"/>
							</Anchors>
							<TexCoords left="0.41601563" right="0.42285156" top="0.91796875" bottom="0.94531250"/>
						</Texture>
						<Texture parentKey="RightDivider" file="Interface\GuildFrame\GuildFrame">
							<Size x="7" y="14"/>
							<Anchors>
								<Anchor point="RIGHT" x="-66" y="0"/>
							</Anchors>
							<TexCoords left="0.41601563" right="0.42285156" top="0.91796875" bottom="0.94531250"/>
						</Texture>
					</Layer>
					<Layer level="ARTWORK" textureSubLevel="1">
						<FontString parentKey="Label" inherits="GameFontHighlightMedium" justifyH="LEFT">
							<Anchors>
								<Anchor point="CENTER" x="0" y="0"/>
							</Anchors>
						</FontString>
					</Layer>
					<Layer level="BACKGROUND" textureSubLevel="-1">
						<Texture>
							<Color r="0.04" g="0.07" b="0.18"/>
						</Texture>
					</Layer>
				</Layers>
				<BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
				<BarColor r="0.26" g="0.42" b="1"/>
			</StatusBar>
		</Frames>
	</Frame>
</Ui>
