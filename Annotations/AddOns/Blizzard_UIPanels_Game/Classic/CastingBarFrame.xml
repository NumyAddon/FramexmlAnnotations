<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\Blizzard_SharedXML\UI.xsd">
	<StatusBar name="CastingBarFrameAnimsFXTemplate" inherits="CastingBarFrameAnimsTemplate" virtual="true">
		<!-- Classic has a much more limited set of FX than Mainline. -->
		<!-- Additionally, in Classic, this Flash is used by both the standard and small cast bars. -->
		<Animations>
			<AnimationGroup parentKey="FlashAnim" setToFinalAlpha="true">
				<Alpha childKey="Flash" fromAlpha="0" toAlpha="1" duration="0.08"/>
			</AnimationGroup>
		</Animations>
	</StatusBar>
	<StatusBar name="CastingBarFrameTemplate" mixin="CastingBarMixin" inherits="CastingBarFrameAnimsFXTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="classicStyleCastBar" value="true" type="boolean"/>
		</KeyValues>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture setAllPoints="true">
					<Color r="0" g="0" b="0" a="0.5"/>
				</Texture>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="1">
				<Texture parentKey="Border" file="Interface\CastingBar\UI-CastingBar-Border">
					<Size x="256" y="64"/>
					<Anchors>
						<Anchor point="TOP" x="0" y="28"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="2">
				<Texture parentKey="BorderShield" file="Interface\CastingBar\UI-CastingBar-Small-Shield" hidden="true">
					<Size x="256" y="64"/>
					<Anchors>
						<Anchor point="TOP" x="0" y="28"/>
					</Anchors>
				</Texture>
				<FontString parentKey="Text" inherits="GameFontHighlight">
					<Size x="185" y="16"/>
					<Anchors>
						<Anchor point="TOP" x="0" y="5"/>
					</Anchors>
				</FontString>
				<Texture parentKey="Icon">
					<Size x="18" y="18"/>
					<Anchors>
						<Anchor point="RIGHT" relativeTo="$parent" relativePoint="LEFT" x="-3.5" y="1"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="OVERLAY">
				<Texture parentKey="Spark" file="Interface\CastingBar\UI-CastingBar-Spark" alphaMode="ADD">
					<Size x="32" y="32"/>
					<Anchors >
						<Anchor point="CENTER" x="0" y="2"/>
					</Anchors>
				</Texture>
				<Texture parentKey="Flash" file="Interface\CastingBar\UI-CastingBar-Flash" alphaMode="ADD">
					<Size x="256" y="64"/>
					<Anchors>
						<Anchor point="TOP" x="0" y="28"/>
					</Anchors>
					<Color r="1.0" g="0.7" b="0.0"/>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				self:OnLoad(nil, true, false);
			</OnLoad>
			<OnEvent method="OnEvent" />
			<OnUpdate method="OnUpdate" />
			<OnShow method="OnShow" />
		</Scripts>
		<BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
		<BarColor r="1.0" g="0.7" b="0.0"/>
	</StatusBar>
	<StatusBar name="SmallCastingBarFrameTemplate" mixin="CastingBarMixin" inherits="CastingBarFrameAnimsFXTemplate" virtual="true">
		<Size x="150" y="10"/>
		<KeyValues>
			<KeyValue key="classicStyleCastBar" value="true" type="boolean"/>
		</KeyValues>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture setAllPoints="true">
					<Color r="0" g="0" b="0" a="0.5"/>
				</Texture>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="1">
				<Texture parentKey="Border" file="Interface\CastingBar\UI-CastingBar-Border-Small">
					<Size x="0" y="56"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="-23" y="23"/>
						<Anchor point="TOPRIGHT" x="23" y="23"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="2">
				<Texture parentKey="BorderShield" file="Interface\CastingBar\UI-CastingBar-Small-Shield" hidden="true">
					<Size x="0" y="56"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="-28" y="23"/>
						<Anchor point="TOPRIGHT" x="18" y="23"/>
					</Anchors>
				</Texture>
				<FontString parentKey="Text" inherits="SystemFont_Shadow_Small">
					<Size x="0" y="16"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="0" y="4"/>
						<Anchor point="TOPRIGHT" x="0" y="4"/>
					</Anchors>
				</FontString>
			</Layer>
			<Layer level="OVERLAY">
				<Texture parentKey="Icon">
					<Size x="18" y="18"/>
					<Anchors>
						<Anchor point="RIGHT" relativeTo="$parent" relativePoint="LEFT" x="-3.5" y="1"/>
					</Anchors>
				</Texture>
				<Texture parentKey="Spark" file="Interface\CastingBar\UI-CastingBar-Spark" alphaMode="ADD">
					<Size x="32" y="32"/>
					<Anchors>
						<Anchor point="CENTER" x="0" y="0"/>
					</Anchors>
				</Texture>
				<Texture parentKey="Flash" file="Interface\CastingBar\UI-CastingBar-Flash-Small" alphaMode="ADD">
					<Size x="0" y="56"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="-23" y="23"/>
						<Anchor point="TOPRIGHT" x="23" y="23"/>
					</Anchors>
					<Color r="1.0" g="0.7" b="0.0"/>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				self:OnLoad(nil, true, false);
			</OnLoad>
			<OnEvent method="OnEvent" />
			<OnUpdate method="OnUpdate" />
			<OnShow method="OnShow" />
		</Scripts>
		<BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
		<BarColor r="1.0" g="0.7" b="0.0"/>
	</StatusBar>

	<StatusBar name="PlayerCastingBarFrame" toplevel="true" inherits="CastingBarFrameTemplate, UIParentBottomManagedFrameTemplate, EditModeCastBarSystemTemplate" fixedFrameStrata="true" frameStrata="HIGH" mixin="PlayerCastingBarMixin">
		<Size x="195" y="13"/>
		<KeyValues>
			<KeyValue key="layoutIndex" value="2" type="number"/>
			<KeyValue key="bottomPadding" value="70" type="number"/>
			<KeyValue key="editModeSelectionTopOffset" value="4" type="number"/>
			<KeyValue key="editModeSelectionBottomOffset" value="0" type="number"/>
		</KeyValues>
		<Scripts>
			<OnLoad method="OnLoad" inherit="append"/>
			<OnShow method="OnShow"/>
		</Scripts>
	</StatusBar>
	
	<StatusBar name="OverlayPlayerCastingBarFrame" toplevel="true" inherits="CastingBarFrameTemplate" parent="UIParent" hidden="true" frameStrata="HIGH" mixin="OverlayPlayerCastingBarMixin">
		<Size x="195" y="13"/>
		<KeyValues>
			<KeyValue key="playCastFX" value="true" type="boolean"/>
		</KeyValues>
		<Anchors>
			<Anchor point="CENTER" x="0" y="0"/>
		</Anchors>
		<Scripts>
			<OnLoad method="OnLoad"/>
		</Scripts>
	</StatusBar>
</Ui>
