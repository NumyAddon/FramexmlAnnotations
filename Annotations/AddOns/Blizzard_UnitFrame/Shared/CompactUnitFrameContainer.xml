<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\Blizzard_SharedXML\UI.xsd">

	<Button name="ContainedCompactUnitFrameTemplate" inherits="CompactUnitFrameTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="ignoreCUFNameRequirement" value="true" type="boolean"/>
		</KeyValues>
	</Button>

	<Frame name="CompactUnitFrameContainerTemplate" mixin="CompactUnitFrameContainerMixin" inherits="GridLayoutFrame" hidden="true" virtual="true">
		<!-- Use GridLayoutFrame key-values to control layout for your derived frame. -->
		<KeyValues>
			<KeyValue key="childXPadding" value="0" type="number"/>
			<KeyValue key="childYPadding" value="0" type="number"/>
			<KeyValue key="stride" value="1" type="number"/>
		</KeyValues>
		<Size x="1" y="1"/>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnShow method="OnShow"/>
			<OnEvent method="OnEvent"/>
		</Scripts>
	</Frame>
</Ui>
