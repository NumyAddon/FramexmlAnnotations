<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\Blizzard_SharedXML\UI.xsd">
	<ScopedModifier useForbiddenObjectTable="true">
		<AuraContainer name="TargetFrameAuraContainerTemplate" virtual="true">
			<KeyValues>
				<KeyValue key="privateAurasEnabled" value="true" type="boolean"/>

				<KeyValue key="maxBuffs" value="TargetFrameAuraContainerDefaults.MaxBuffs" type="global"/>
				<KeyValue key="maxDebuffs" value="TargetFrameAuraContainerDefaults.MaxDebuffs" type="global"/>

				<KeyValue key="buffFilterString" value="TargetFrameAuraContainerDefaults.BuffFilterString" type="global"/>
				<KeyValue key="debuffFilterString" value="TargetFrameAuraContainerDefaults.DebuffFilterString" type="global"/>

				<KeyValue key="smallAuraSize" value="TargetFrameAuraContainerDefaults.SmallAuraSize" type="global"/>
				<KeyValue key="largeAuraSize" value="TargetFrameAuraContainerDefaults.LargeAuraSize" type="global"/>

				<KeyValue key="auraElementSpacingX" value="TargetFrameAuraContainerDefaults.AuraElementSpacingX" type="global"/>
				<KeyValue key="auraElementSpacingY" value="TargetFrameAuraContainerDefaults.AuraElementSpacingY" type="global"/>

				<KeyValue key="auraPaddingLeft" value="TargetFrameAuraContainerDefaults.AuraPaddingLeft" type="global"/>
				<KeyValue key="auraPaddingRight" value="TargetFrameAuraContainerDefaults.AuraPaddingRight" type="global"/>
				<KeyValue key="auraPaddingTop" value="TargetFrameAuraContainerDefaults.AuraPaddingTop" type="global"/>
				<KeyValue key="auraPaddingBottom" value="TargetFrameAuraContainerDefaults.AuraPaddingBottom" type="global"/>

				<KeyValue key="constrainedAuraRowWidth" value="TargetFrameAuraContainerDefaults.ConstrainedAuraRowWidth" type="global"/>
				<KeyValue key="auraRowWidth" value="TargetFrameAuraContainerDefaults.AuraRowWidth" type="global"/>
				<KeyValue key="numConstrainedAuraRows" value="TargetFrameAuraContainerDefaults.NumConstrainedAuraRows" type="global"/>

				<KeyValue key="mirrorVertically" value="TargetFrameAuraContainerDefaults.MirrorVertically" type="global"/>
				<KeyValue key="showAuraCount" value="TargetFrameAuraContainerDefaults.ShowAuraCount" type="global"/>
			</KeyValues>
			<Mixins>
				<Mixin key="TargetFrameAuraContainerInboundMixin" source="secure" targetPartition="public" inboundPartition="forbidden" secureDelegates="true"/>
				<Mixin key="TargetFrameAuraContainerPrivateMixin" source="secure"/>
			</Mixins>
			<Scripts>
				<OnLoad method="OnLoad"/>
				<OnUpdate method="OnUpdate"/>
			</Scripts>
		</AuraContainer>
	</ScopedModifier>
</Ui>
