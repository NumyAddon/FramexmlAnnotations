<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\Blizzard_SharedXML\UI.xsd">
	<Frame name="VisualAlertBaseTemplate" inherits="AnimateWhileShownTemplate" mixin="VisualAlertBaseMixin" hidden="true" virtual="true">
		<KeyValues>
			<KeyValue key="vertexColor" value="VISUAL_ALERT_COLOR_GOLD" type="global"/>
			<KeyValue key="durationSeconds" value="2" type="number"/>
		</KeyValues>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnShow method="OnShow"/>
			<OnUpdate method="OnUpdate"/>
		</Scripts>
	</Frame>

	<Frame name="VisualAlertMarchingAntsBaseTemplate" inherits="VisualAlertBaseTemplate" mixin="VisualAlertMarchingAntsBaseMixin" virtual="true">
		<Layers>
			<Layer level="ARTWORK">
				<Texture parentKey="Flipbook" atlas="VisualAlert_Ants_Flipbook" setAllPoints="true"/>
			</Layer>
		</Layers>
		<Animations>
			<AnimationGroup looping="REPEAT" setToFinalAlpha="true">
				<FlipBook childKey="Flipbook" duration="1" order="1" flipBookRows="6" flipBookColumns="5" flipBookFrames="30" flipBookFrameWidth="0" flipBookFrameHeight="0"/>
			</AnimationGroup>
		</Animations>
	</Frame>

	<Frame name="VisualAlertMarchingAntsCyanTemplate" inherits="VisualAlertMarchingAntsBaseTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="vertexColor" value="VISUAL_ALERT_COLOR_CYAN" type="global"/>
		</KeyValues>
	</Frame>

	<Frame name="VisualAlertMarchingAntsRedTemplate" inherits="VisualAlertMarchingAntsBaseTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="vertexColor" value="VISUAL_ALERT_COLOR_RED" type="global"/>
		</KeyValues>
	</Frame>

	<Frame name="VisualAlertMarchingAntsGreenTemplate" inherits="VisualAlertMarchingAntsBaseTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="vertexColor" value="VISUAL_ALERT_COLOR_GREEN" type="global"/>
		</KeyValues>
	</Frame>

	<Frame name="VisualAlertMarchingAntsBlueTemplate" inherits="VisualAlertMarchingAntsBaseTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="vertexColor" value="VISUAL_ALERT_COLOR_BLUE" type="global"/>
		</KeyValues>
	</Frame>

	<Frame name="VisualAlertFlashBaseTemplate" inherits="VisualAlertBaseTemplate" mixin="VisualAlertFlashBaseMixin" virtual="true">
		<Layers>
			<Layer level="ARTWORK">
				<Texture parentKey="Glow" atlas="UI-CooldownManager-VisualAlert-Glow" setAllPoints="true"/>
			</Layer>
		</Layers>
		<Animations>
			<AnimationGroup looping="BOUNCE" setToFinalAlpha="true">
				<Alpha childKey="Glow" duration="0.5" order="1" smoothing="IN_OUT" fromAlpha="0.25" toAlpha="1"/>
			</AnimationGroup>
		</Animations>
	</Frame>

	<Frame name="VisualAlertFlashCyanTemplate" inherits="VisualAlertFlashBaseTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="vertexColor" value="VISUAL_ALERT_COLOR_CYAN" type="global"/>
		</KeyValues>
	</Frame>

	<Frame name="VisualAlertFlashRedTemplate" inherits="VisualAlertFlashBaseTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="vertexColor" value="VISUAL_ALERT_COLOR_RED" type="global"/>
		</KeyValues>
	</Frame>

	<Frame name="VisualAlertFlashGreenTemplate" inherits="VisualAlertFlashBaseTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="vertexColor" value="VISUAL_ALERT_COLOR_GREEN" type="global"/>
		</KeyValues>
	</Frame>

	<Frame name="VisualAlertFlashBlueTemplate" inherits="VisualAlertFlashBaseTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="vertexColor" value="VISUAL_ALERT_COLOR_BLUE" type="global"/>
		</KeyValues>
	</Frame>
</Ui>
